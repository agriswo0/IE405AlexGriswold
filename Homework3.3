#include <iostream>

void coinToss(){
    int times;
    std::cout<<"How many times do you wish to flip coin? ";
    std::cin>>times;
    
    for(int i=0;i<times;i++){
        int tosses = rand()%2+1;
        
        if(tosses==1){
            std::cout<<"Heads ";
        }
        else{
            std::cout<<"Tails ";
        }
    }
}

int main() {
    coinToss();
}
